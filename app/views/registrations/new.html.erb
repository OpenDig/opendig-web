<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Create an account — OpenDig</title>
  <%= csrf_meta_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@500;600&family=Archivo:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root{--sand:#f4ecdd;--paper:#fbf6ec;--ink:#2a231b;--ink-soft:#6a5d4c;
      --line:#ddcfb4;--rust:#b1542b;--rust-deep:#8d3f1d;--clay:#9c6b3f;--err:#9c2b1a}
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Archivo',system-ui,sans-serif;background:var(--sand);color:var(--ink);
      min-height:100vh;display:flex;flex-direction:column}
    a{text-decoration:none;color:inherit}
    .top{max-width:1180px;width:100%;margin:0 auto;padding:1.25rem clamp(1rem,5vw,3.5rem)}
    .brand{font-family:'Spectral',serif;font-weight:600;font-size:1.5rem}
    .brand b{color:var(--rust)}
    .wrap{flex:1;display:grid;place-items:center;padding:1.5rem}
    .card{width:100%;max-width:25rem;background:var(--paper);border:1px solid var(--line);
      border-radius:18px;padding:2.2rem 2rem;box-shadow:0 12px 40px rgba(111,74,44,.08)}
    .eyebrow{font-size:.75rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--clay)}
    h1{font-family:'Spectral',serif;font-weight:600;font-size:1.9rem;margin:.4rem 0 .4rem}
    .sub{color:var(--ink-soft);font-size:.95rem;margin-bottom:1.5rem}
    .err{background:#f7e3dd;border:1px solid #e3b6aa;color:var(--err);border-radius:10px;
      padding:.65rem .85rem;font-size:.9rem;margin-bottom:1.1rem}
    label{display:block;font-size:.85rem;font-weight:600;color:var(--ink-soft);margin-bottom:.35rem}
    .field{margin-bottom:1rem}
    input{width:100%;padding:.7rem .85rem;border:1.5px solid var(--line);border-radius:10px;
      font:inherit;background:#fff;color:var(--ink)}
    input:focus{outline:none;border-color:var(--clay)}
    .hint{font-size:.78rem;color:var(--ink-soft);margin-top:.3rem}
    .submit{width:100%;background:var(--rust);color:#fff;border:none;border-radius:10px;
      padding:.75rem;font:inherit;font-weight:600;cursor:pointer}
    .submit:hover{background:var(--rust-deep)}
    .divider{display:flex;align-items:center;gap:.8rem;color:var(--ink-soft);font-size:.8rem;
      text-transform:uppercase;letter-spacing:.1em;margin:1.3rem 0}
    .divider::before,.divider::after{content:"";flex:1;height:1px;background:var(--line)}
    .providers form{margin:0}
    .prov{display:flex;align-items:center;justify-content:center;gap:.6rem;width:100%;
      padding:.7rem 1rem;border-radius:10px;font-weight:600;font-size:.98rem;border:1.5px solid var(--line);
      background:#fff;color:var(--ink);transition:.15s;cursor:pointer}
    .prov:hover{border-color:var(--clay);background:var(--paper)}
    .prov svg{width:20px;height:20px}
    .foot{text-align:center;color:var(--ink-soft);font-size:.9rem;margin-top:1.5rem}
    .foot a{color:var(--rust);font-weight:600}
  </style>
</head>
<body>
  <% domain = "#{request.protocol}#{request.domain}#{request.optional_port ? ":#{request.optional_port}" : ''}/" %>
  <header class="top"><a href="<%= domain %>" class="brand">Open<b>Dig</b></a></header>

  <div class="wrap">
    <div class="card">
      <p class="eyebrow">Get started</p>
      <h1>Create your account</h1>
      <p class="sub">Sign up, then ask a dig director to invite your email to a dig.</p>

      <% if flash[:error] %><div class="err"><%= flash[:error] %></div><% end %>

      <%= form_with url: signup_path, method: :post do |f| %>
        <div class="field">
          <%= f.label :name, "Name" %>
          <%= f.text_field :name, value: @name, autofocus: true, autocomplete: "name", required: true %>
        </div>
        <div class="field">
          <%= f.label :email, "Email" %>
          <%= f.email_field :email, value: @email, autocomplete: "email", required: true %>
        </div>
        <div class="field">
          <%= f.label :password, "Password" %>
          <%= f.password_field :password, autocomplete: "new-password", required: true %>
          <p class="hint">At least 8 characters.</p>
        </div>
        <div class="field">
          <%= f.label :password_confirmation, "Confirm password" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true %>
        </div>
        <%= f.submit "Create account", class: "submit" %>
      <% end %>

      <div class="divider">or sign up with</div>

      <%= button_to auth_path("google_oauth2"), method: :post, class: "prov" do %>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Google
      <% end %>

      <p class="foot">Already have an account? <a href="<%= login_path %>">Sign in</a></p>
    </div>
  </div>
</body>
</html>
