<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Loci Search Results</h1>
    <p class="mt-2 text-gray-600">
      Query:
      <span class="font-semibold"><%= @search_query.presence || 'None' %></span>
    </p>
  </div>

  <% if @search_query.blank? %>
    <div class="rounded border border-yellow-200 bg-yellow-50 p-4 text-yellow-800">
      Enter a locus code in the menu search bar to view results.
    </div>
  <% elsif @search_results.empty? %>
    <div class="rounded border border-gray-200 bg-white p-4 text-gray-700">
      No loci matched this query.
    </div>
  <% else %>
    <div class="mb-3 text-sm text-gray-600">
      Found <%= @search_results.size %> result<%= 's' unless @search_results.size == 1 %>.
    </div>
    <div class="overflow-hidden rounded border border-gray-200 bg-white">
      <% @search_results.each do |result| %>
        <%= link_to result[:url], class: 'block border-b border-gray-100 px-4 py-3 hover:bg-gray-50 last:border-b-0' do %>
          <div class="font-semibold text-blue-700"><%= result[:label] %></div>
          <div class="text-sm text-gray-600">Area <%= result[:area] %>, Square <%= result[:square] %>, Locus <%= result[:code] %></div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
