<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dig not found — OpenDig</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@500;600&family=Archivo:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root{--sand:#f4ecdd;--ink:#2a231b;--ink-soft:#6a5d4c;--rust:#b1542b;--rust-deep:#8d3f1d;--line:#ddcfb4}
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Archivo',system-ui,sans-serif;background:var(--sand);color:var(--ink);
      min-height:100vh;display:grid;place-items:center;text-align:center;padding:2rem}
    .card{max-width:30rem}
    .code{font-family:'Spectral',serif;font-size:4rem;font-weight:600;color:var(--rust);line-height:1}
    h1{font-family:'Spectral',serif;font-weight:600;font-size:1.6rem;margin:.6rem 0 .5rem}
    p{color:var(--ink-soft);line-height:1.55;margin-bottom:1.4rem}
    a{display:inline-block;background:var(--rust);color:#fff;border-radius:999px;
      padding:.6rem 1.3rem;font-weight:600;text-decoration:none}
    a:hover{background:var(--rust-deep)}
  </style>
</head>
<body>
  <div class="card">
    <div class="code">404</div>
    <h1>That dig isn't here</h1>
    <p>We couldn't find a dig at this address. Check the link, or head to OpenDig to pick one of your digs.</p>
    <a href="<%= "#{request.protocol}#{request.domain}#{request.optional_port ? ":#{request.optional_port}" : ''}/" %>">Go to OpenDig</a>
  </div>
</body>
</html>
