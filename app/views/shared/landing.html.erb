<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>OpenDig — the excavation record</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --sand:#f4ecdd; --paper:#fbf6ec; --sand-deep:#e8dcc5;
      --ink:#2a231b; --ink-soft:#6a5d4c; --line:#ddcfb4;
      --rust:#b1542b; --rust-deep:#8d3f1d; --ochre:#c08a3e; --clay:#9c6b3f; --umber:#6f4a2c;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased}
    body{font-family:'Archivo',system-ui,sans-serif;color:var(--ink);background:var(--sand);
      min-height:100vh;display:flex;flex-direction:column}
    a{color:inherit;text-decoration:none}

    .topbar{display:flex;align-items:center;justify-content:space-between;
      padding:1.25rem clamp(1rem,5vw,3.5rem);max-width:1180px;margin:0 auto;width:100%}
    .brand{font-family:'Spectral',serif;font-weight:600;font-size:1.5rem;letter-spacing:.01em}
    .brand b{color:var(--rust);font-weight:600}
    .topnav{display:flex;align-items:center;gap:1.25rem;font-size:.95rem}
    .topnav .who{color:var(--ink-soft)}
    .btn{display:inline-block;border-radius:999px;padding:.55rem 1.1rem;font-weight:600;
      font-size:.95rem;border:1.5px solid transparent;transition:.15s}
    .btn-primary{background:var(--rust);color:#fff}
    .btn-primary:hover{background:var(--rust-deep)}
    .btn-ghost{border-color:var(--line);color:var(--ink)}
    .btn-ghost:hover{border-color:var(--clay);background:var(--paper)}

    main{flex:1;width:100%}
    .hero{max-width:1180px;margin:0 auto;padding:clamp(2.5rem,7vw,6rem) clamp(1rem,5vw,3.5rem) 0}
    .eyebrow{font-size:.8rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;
      color:var(--clay);margin-bottom:1.1rem}
    h1{font-family:'Spectral',serif;font-weight:600;line-height:1.02;letter-spacing:-.01em;
      font-size:clamp(2.6rem,7vw,5rem);max-width:14ch}
    h1 em{font-style:italic;color:var(--rust)}
    .lede{font-size:clamp(1.05rem,2vw,1.3rem);line-height:1.55;color:var(--ink-soft);
      max-width:46ch;margin:1.5rem 0 2.2rem}
    .cta-row{display:flex;flex-wrap:wrap;gap:.8rem;align-items:center}
    .cta-note{color:var(--ink-soft);font-size:.9rem}

    /* Soil stratigraphy band — the section drawing an archaeologist records */
    .strata{margin-top:clamp(2.5rem,6vw,4.5rem);height:120px;position:relative;overflow:hidden;
      border-top:1px solid var(--line)}
    .strata i{position:absolute;left:0;right:0;display:block}
    .l1{top:0;height:26px;background:var(--sand-deep)}
    .l2{top:26px;height:30px;background:var(--ochre);opacity:.55}
    .l3{top:56px;height:22px;background:var(--clay);opacity:.5}
    .l4{top:78px;height:42px;background:var(--umber);opacity:.45}
    .strata .find{position:absolute;width:9px;height:9px;border-radius:50%;
      background:var(--rust);box-shadow:0 0 0 4px rgba(177,84,43,.18)}
    .strata .f1{top:64px;left:18%}.strata .f2{top:92px;left:54%}.strata .f3{top:40px;left:78%}
    .strata .datum{position:absolute;top:13px;left:0;right:0;border-top:1.5px dashed rgba(42,35,27,.35)}

    /* Your digs */
    .digs{max-width:1180px;margin:0 auto;padding:clamp(2.5rem,6vw,4rem) clamp(1rem,5vw,3.5rem)}
    .digs h2{font-family:'Spectral',serif;font-weight:600;font-size:1.6rem;margin-bottom:.4rem}
    .digs p.sub{color:var(--ink-soft);margin-bottom:1.6rem}
    .dig-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem}
    .dig-card{background:var(--paper);border:1px solid var(--line);border-radius:14px;
      padding:1.2rem 1.3rem;display:flex;flex-direction:column;gap:.5rem;transition:.15s}
    .dig-card:hover{border-color:var(--clay);transform:translateY(-2px);box-shadow:0 8px 24px rgba(111,74,44,.1)}
    .dig-card .name{font-family:'Spectral',serif;font-size:1.35rem;font-weight:600}
    .dig-card .go{color:var(--rust);font-weight:600;font-size:.9rem}
    .empty{background:var(--paper);border:1px dashed var(--line);border-radius:14px;
      padding:1.6rem;color:var(--ink-soft)}

    footer{border-top:1px solid var(--line);margin-top:auto}
    .foot{max-width:1180px;margin:0 auto;padding:1.4rem clamp(1rem,5vw,3.5rem);
      display:flex;flex-wrap:wrap;gap:.6rem 1.2rem;align-items:center;color:var(--ink-soft);font-size:.9rem}
    .foot a:hover{color:var(--rust)}
    .foot .dot{opacity:.5}
  </style>
</head>
<body>
  <% signed_in = user_signed_in? %>
  <% digs = signed_in ? (current_user.superuser? ? Project.all : (current_user.roles.keys & Project.all)).sort : [] %>
  <% port = request.optional_port ? ":#{request.optional_port}" : "" %>

  <header class="topbar">
    <div class="brand">Open<b>Dig</b></div>
    <nav class="topnav">
      <% if signed_in %>
        <span class="who"><%= current_user.name.presence || current_user.email %></span>
        <%= button_to "Sign out", logout_path, method: :delete, class: "btn btn-ghost",
              form: { style: "display:inline" }, data: { confirm: "Sign out of OpenDig?" } %>
      <% else %>
        <a class="btn btn-primary" href="<%= login_path %>">Sign in</a>
      <% end %>
    </nav>
  </header>

  <main>
    <section class="hero">
      <p class="eyebrow">Archaeological excavation records</p>
      <h1>The dig, written down <em>once</em>.</h1>
      <p class="lede">
        OpenDig keeps every area, square, locus, pail, and find in one shared record —
        from the trench to the lab, on any device, online or off.
      </p>
      <% unless signed_in %>
        <div class="cta-row">
          <a class="btn btn-primary" href="<%= login_path %>">Sign in to your dig</a>
          <a class="btn btn-ghost" href="<%= signup_path %>">Create an account</a>
          <span class="cta-note">Sign in with Google or your email.</span>
        </div>
      <% end %>
    </section>

    <div class="strata" aria-hidden="true">
      <i class="l1"></i><i class="l2"></i><i class="l3"></i><i class="l4"></i>
      <span class="datum"></span>
      <span class="find f1"></span><span class="find f2"></span><span class="find f3"></span>
    </div>

    <% if signed_in %>
      <section class="digs">
        <div style="display:flex;align-items:flex-end;gap:1rem;flex-wrap:wrap;margin-bottom:1.6rem">
          <div>
            <h2>Your digs</h2>
            <p class="sub" style="margin-bottom:0">Projects you have access to. Pick one to enter the field record.</p>
          </div>
          <% if current_user.superuser? %>
            <a class="btn btn-primary" style="margin-left:auto" href="<%= projects_path %>">Manage projects</a>
          <% end %>
        </div>
        <% if digs.any? %>
          <div class="dig-grid">
            <% digs.each do |key| %>
              <% cover = Project.cover_photo_url(key, :thumb) %>
              <% desc = Project.description(key) %>
              <a class="dig-card" href="<%= "#{request.protocol}#{key}.#{request.domain}#{port}/" %>">
                <% if cover.present? %>
                  <img src="<%= cover %>" alt="" style="width:100%;height:120px;object-fit:cover;border-radius:10px;margin-bottom:.3rem">
                <% end %>
                <span class="name"><%= Project.display_name(key) %></span>
                <% if desc.present? %>
                  <span style="color:var(--ink-soft);font-size:.9rem;line-height:1.45"><%= truncate(desc, length: 130) %></span>
                <% end %>
                <span class="go">Enter the dig →</span>
              </a>
            <% end %>
          </div>
        <% else %>
          <div class="empty">
            You're signed in, but no dig has been shared with you yet. Ask a dig director to invite
            your email, then sign in again.
          </div>
        <% end %>
      </section>
    <% end %>
  </main>

  <footer>
    <div class="foot">
      <span class="brand" style="font-size:1rem">Open<b>Dig</b></span>
      <span class="dot">·</span>
      <a href="<%= about_path %>">About</a>
      <span class="dot">·</span>
      <a href="<%= help_path %>">Help</a>
    </div>
  </footer>
</body>
</html>
